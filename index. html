<!DOCTYPE html>
<html lang="ms">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MotoVote</title>

<link rel="stylesheet" href="style.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>

<body>

<div class="bg1"></div>
<div class="bg2"></div>

<header class="header">
  <h1>MOTOVOTE</h1>
  <div>🏍️</div>
</header>

<section class="hero">
  <h2>Undian Moto Malaysia</h2>
  <p>Pilih motor kegemaran anda</p>
</section>

<section class="cards">

  <div class="card">
    <h3>Y15ZR</h3>
    <p id="y15count">0 Undi</p>
    <button onclick="vote('Y15ZR')">Undi</button>
  </div>

  <div class="card">
    <h3>RS150R</h3>
    <p id="rscount">0 Undi</p>
    <button onclick="vote('RS150R')">Undi</button>
  </div>

  <div class="card">
    <h3>RXZ</h3>
    <p id="rxzcount">0 Undi</p>
    <button onclick="vote('RXZ')">Undi</button>
  </div>

</section>

<section class="results">
  <h2>Result</h2>

  <p>Y15ZR: <span id="y15percent">0%</span></p>
  <p>RS150R: <span id="rspercent">0%</span></p>
  <p>RXZ: <span id="rxzpercent">0%</span></p>

  <div id="ranking"></div>
</section>

<script src="script.js"></script>
</body>
</html>
